{
  "name": "withlocals-partner-api-spec",
  "version": "0.1.0-draft",
  "private": true,
  "description": "OpenAPI 3.1 spec for the Withlocals partner API.",
  "scripts": {
    "bundle": "redocly bundle openapi.yaml -o dist/openapi.yaml",
    "docs": "node -e \"require('fs').copyFileSync('index.html','dist/index.html');console.log('copied index.html -> dist/index.html');\"",
    "copy-assets": "node -e \"const f=require('fs');if(f.existsSync('assets')){f.cpSync('assets','dist/assets',{recursive:true});console.log('copied assets/ -> dist/assets/');}\"",
    "mock": "prism mock openapi.yaml",
    "lint:redocly": "redocly lint openapi.yaml",
    "lint:spectral": "spectral lint dist/openapi.yaml --ruleset .spectral.yaml",
    "lint": "yarn lint:redocly && yarn bundle && yarn lint:spectral",
    "build": "rimraf dist && yarn bundle && yarn docs && yarn copy-assets",
    "preview": "yarn build && serve dist -l 3001"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "@stoplight/prism-cli": "^5.10.0",
    "@stoplight/spectral-cli": "^6.13.0",
    "rimraf": "^5.0.5",
    "serve": "^14.2.6"
  }
}
