{
  "name": "withlocals-partner-api-spec",
  "version": "1.0.0",
  "private": true,
  "description": "OpenAPI 3.1 spec for the Withlocals partner API.",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "bundle": "redocly bundle openapi.yaml -o dist/api-reference/openapi.yaml",
    "docs": "node scripts/copy-docs.mjs",
    "copy-assets": "node scripts/copy-assets.mjs",
    "lint:spectral": "spectral lint dist/api-reference/openapi.yaml --ruleset .spectral.yaml",
    "lint": "yarn bundle && yarn lint:spectral",
    "build": "rimraf dist && yarn bundle && yarn docs && yarn copy-assets",
    "preview": "yarn build && serve dist -l 3001"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "@stoplight/spectral-cli": "^6.13.0",
    "rimraf": "^5.0.5",
    "serve": "^14.2.6"
  }
}
